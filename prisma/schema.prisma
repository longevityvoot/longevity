// Prisma schema — Longevity Designer
// Full schema lives in handoff/spec-v0.2.md §7. Phase 1 will expand this.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COACH
  CLIENT
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role
  createdAt DateTime @default(now())
}
